{
  "name": "nestjs-starter",
  "version": "0.0.1",
  "description": "Production-ready NestJS boilerplate",
  "author": "krylov@vasily.dev",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "init-project": "./scripts/init.ts",
    "sync": "./scripts/sync.sh",
    "dev": "NODE_OPTIONS='-r ./env.js' nest start --watch",
    "dev:email": "email dev --dir src/notifications/channels/email/templates --port 3001",
    "build": "nest build",
    "start": "NODE_OPTIONS='-r ./env.js' nest start",
    "lint": "biome check --write --no-errors-on-unmatched .",
    "lint:ci": "biome ci --no-errors-on-unmatched --reporter=github .",
    "debug": "NODE_OPTIONS='-r ./env.js' nest start --watch --debug",
    "start:prod": "node -r ./env.js dist/main",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:generate-api": "wait-on http://localhost:3000/docs-json -t 5000 && rm -rf e2e/api/model e2e/api/generated.ts && orval --config orval.config.ts",
    "prepare": "husky 2>/dev/null || true",
    "typeorm": "NODE_OPTIONS='-r ./env.js -r tsconfig-paths/register' ts-node node_modules/typeorm/cli",
    "migration:generate": "pnpm typeorm migration:generate -d src/data-source.ts",
    "migration:create": "pnpm typeorm migration:create",
    "migration:run": "pnpm typeorm migration:run -d src/data-source.ts",
    "migration:revert": "pnpm typeorm migration:revert -d src/data-source.ts",
    "migration:show": "pnpm typeorm migration:show -d src/data-source.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.982.0",
    "@aws-sdk/s3-request-presigner": "^3.982.0",
    "@nestjs/common": "^11.1.13",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.13",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@react-email/components": "^1.0.6",
    "@sentry/node": "^10.38.0",
    "@thallesp/nestjs-better-auth": "^2.2.5",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.4.18",
    "compression": "^1.8.1",
    "fast-redact": "^3.5.0",
    "helmet": "^8.1.0",
    "nestjs-pino": "^4.5.0",
    "nestjs-zod": "^5.1.1",
    "pg": "^8.18.0",
    "pg-error-constants": "^1.0.0",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.1",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "uuidv7": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@playwright/test": "^1.58.2",
    "@react-email/preview-server": "5.2.8",
    "@readme/openapi-parser": "^5.5.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@types/tough-cookie": "^4.0.5",
    "axios-cookiejar-support": "^6.0.5",
    "cookie": "^1.1.1",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jose": "^6.1.3",
    "lint-staged": "^16.2.7",
    "orval": "^8.2.0",
    "patch-package": "^8.0.1",
    "pino-pretty": "^13.1.3",
    "react-email": "^5.2.6",
    "source-map-support": "^0.5.21",
    "tough-cookie": "^6.0.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
