playwright.config.ts
biome.json
jest.config.ts
tsconfig.json
tsconfig.build.json
Dockerfile
docker-compose.yml
nest-cli.json
commitlint.config.mjs
lint-staged.config.mjs
pnpm-workspace.yaml
package.json

# === Scripts ===
scripts/sync.sh
scripts/setup-s3.sh

# === Dependency patches ===
patches/

