# =============================================================================
# Application Configuration
# =============================================================================
# Copy this file to .env or .env.local and fill in your actual values.
# NEVER commit .env or .env.local files to version control!
#
# Security Note: Keep all secrets secure. Use environment-specific values:
#   - Development: Use local/test values
#   - Production: Use secrets management (GitHub Secrets, Vault, etc.)
# =============================================================================

# =============================================================================
# Environment Configuration
# =============================================================================

# IMPORTANT: Do NOT set NODE_ENV or APP_ENV in .env* files
# Set them via system environment (e.g., APP_ENV=prod pnpm start:prod)

# Application Port
# The port on which the application will listen
# Default: 3000
PORT=3000

# Log Level
# Controls the verbosity of application logs
# Options: trace, debug, info, warn, error, fatal
# Default: 'info' in production, 'debug' in development
# Set to 'warn' or 'error' in production to reduce log volume
LOG_LEVEL=debug

# CORS Origins (Optional)
# Controls allowed origins for NestJS CORS and Better Auth
# Default (empty): localhost on any port | 'true': all origins | 'false': disabled
# Supports wildcards: http://localhost:*, https://*.example.com
# Examples: https://example.com,https://app.example.com
# Note: localhost:* always trusted by Better Auth when using specific origins

# =============================================================================
# Database Configuration
# =============================================================================

# Primary Database URL
# PostgreSQL connection string (required)
# Format: postgresql://user:password@host:port/database?sslmode=require
# Security: Never expose this in logs or client-side code
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestjs_starter?sslmode=disable

# Test Database URL (for E2E tests)
# Separate database for running end-to-end tests
# Required when running: pnpm test:e2e
# Should point to a dedicated test database, never production
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/nestjs_starter_test?sslmode=disable

# =============================================================================
# Authentication Configuration
# =============================================================================

# Auth Secret
# Secret key used for encryption, signing, and hashing in Better Auth
# Generate a secure secret using: openssl rand -base64 32
# Security: Never expose this in logs or client-side code
# Required in production
AUTH_SECRET=your-secret-key-here-must-be-at-least-32-chars-long

# =============================================================================
# Email Configuration (Resend)
# =============================================================================

# Resend API Key
# Get your API key from: https://resend.com/api-keys
# Required for sending transactional emails (OTP, welcome, etc.)
# Security: Keep this secret, never expose in client-side code
RESEND_API_KEY=

# Sender Email Address
# Must be from a verified domain in Resend
# Format: Name <email@domain.com> or just email@domain.com
# Example: MyApp <noreply@myapp.com>
EMAIL_FROM=

# Reply-To Email Address (Optional)
# Where recipients can reply to your emails
# Usually your support email address
EMAIL_REPLY_TO=

# Application Name (Required)
# Used in email templates and subject lines
# Example: My Awesome App
APP_NAME="NestJS Starter Boilerplate"

# =============================================================================
# Error Monitoring (Optional)
# =============================================================================

# Sentry DSN (Data Source Name)
# Leave empty to disable Sentry error tracking
# Get your DSN from: https://sentry.io/settings/projects/
# Only errors with status code >= 500 are sent to Sentry
# Security: This is not a secret, but don't expose it unnecessarily
SENTRY_DSN=

# Sentry Environment
# Identifies the environment in Sentry dashboard
# Options: local, test, dev, stage, prod
# Default: Uses APP_ENV (where code is deployed) if not specified
SENTRY_ENVIRONMENT=local

# =============================================================================
# Media Storage Configuration (S3-compatible)
# =============================================================================
# S3-compatible object storage for media uploads (images, etc.)
# Works with AWS S3, DigitalOcean Spaces, MinIO, etc.
# If not configured, media upload endpoint returns 503 Service Unavailable

# Region (optional for custom endpoints, required for AWS S3)
# Examples: us-east-1, eu-west-1, fra1
# S3_REGION=

# Custom S3 endpoint (optional - omit for AWS S3)
# Examples:
#   DigitalOcean Spaces: https://fra1.digitaloceanspaces.com
#   MinIO: http://localhost:9000
S3_ENDPOINT=https://fra1.digitaloceanspaces.com

# Bucket name
S3_BUCKET=bailaspot

# Access key
# Security: Keep this secret
S3_ACCESS_KEY=

# Secret key
# Security: Keep this secret, never expose in client-side code
S3_SECRET_KEY=

# CDN URL for serving uploaded files (optional)
# If set, file URLs will use CDN instead of direct S3 URL
# Example: https://cdn.example.com
# S3_CDN_URL=

# Path prefix for uploaded files (optional)
# Useful for separating environments within a single bucket
# Default: Uses APP_ENV value (local, dev, stage, prod)
# S3_PREFIX=
